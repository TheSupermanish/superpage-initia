# LLM Provider: "anthropic", "openai", or "google"
LLM_PROVIDER=google
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
# LLM_MODEL=gemini-2.0-flash  # optional, defaults per provider

# Merchant
MERCHANT_URL=http://localhost:3001

# Wallet (0x-prefixed private key with USDC balance on SKALE Base Sepolia)
WALLET_PRIVATE_KEY=0x...

# ERC-8004 Trustless Identity (optional, set after first on-chain registration)
# ERC8004_AGENT_ID=1

# Behavior
MAX_STEPS=20
AUTO_APPROVE_PAYMENTS=false
VERBOSE=true
