{
  "agent": {
    "model": "anthropic/claude-sonnet-4-20250514"
  },
  "mcpServers": {
    "superpage-x402": {
      "command": "node",
      "args": ["./packages/mcp-client/superpage-x402.js"],
      "env": {
        "SUPERPAGE_SERVER": "http://localhost:3001",
        "WALLET_PRIVATE_KEY": "YOUR_WALLET_PRIVATE_KEY_HERE",
        "X402_CHAIN": "base",
        "X402_CURRENCY": "USDC",
        "MAX_AUTO_PAYMENT": "10.00"
      },
      "status": "active"
    }
  },
  "skills": {
    "entries": {
      "moltbook-poster": {
        "enabled": true,
        "env": {
          "MOLTBOOK_API_KEY": "YOUR_MOLTBOOK_API_KEY_HERE"
        }
      }
    }
  }
}
